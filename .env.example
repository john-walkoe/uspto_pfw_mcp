
# =============================================================================
# OAuth sign-in (dual IdP: Google + Entra ID) — HTTP mode only
# =============================================================================
# "none" (default) keeps today's behavior. "oauth" turns the HTTP surface into
# an OAuth 2.1 authorization server: users sign in with Google/Microsoft and
# must have an active row in the mcp_users table (see
# scripts/manage_mcp_users.py and the pfw_manage_users tool). PFW hosts the
# shared paid-tier user DB — point PTAB/FPD *_AUTH_DB_PATH at the same file
# (shared bind mount, same host only).
# PFW_AUTH_MODE=oauth
# PFW_AUTH_BASE_URL=https://your-public-hostname.example.com
# PFW_AUTH_JWT_SECRET=  # openssl rand -hex 32 — rotating logs everyone out
# PFW_AUTH_GOOGLE_CLIENT_ID=
# PFW_AUTH_GOOGLE_CLIENT_SECRET=
# PFW_AUTH_MS_CLIENT_ID=
# PFW_AUTH_MS_CLIENT_SECRET=
# PFW_AUTH_MS_TENANT=common  # common | organizations | tenant GUID
# PFW_AUTH_INTERNAL_TOKEN=   # openssl rand -hex 32 — static bearer for headless clients
# PFW_AUTH_REGISTER_URL=     # optional "Request access" link
# PFW_AUTH_ACCESS_TTL=3600
# PFW_AUTH_REFRESH_TTL=2592000
# PFW_AUTH_DB_PATH=data/mcp_auth.db

# Hardened data directory (0700) for encryption keys and proxy SQLite files.
# Default ~/.uspto_pfw_mcp/data; legacy project-root files migrate on start.
# PFW_DATA_DIR=/path/to/data

# Reverse-proxy peers whose X-Forwarded-For header is trusted for client-IP
# attribution (rate limiting, security audit log). Comma-separated IPs or
# CIDRs, or "*" to trust all (container behind a dedicated proxy only).
# Default 127.0.0.1.
# PROXY_TRUSTED_IPS=127.0.0.1

# Register the pfw_manage_users admin tool. Default false: stdio never needs
# it (use scripts/manage_mcp_users.py), and outside OAuth mode it would be
# protected only by the shared INTERNAL_AUTH_SECRET. Set true on OAuth
# deployments that want the in-chat user-management panel.
# PFW_ENABLE_USER_MANAGEMENT=true

# =============================================================================
# Shared USPTO rate limiting (off by default)
# =============================================================================
# All 4 USPTO MCPs (citations/pfw/ptab/fpd) can run as containers sharing one
# host/netns under a SINGLE USPTO API key. USPTO's documented limits are
# per-KEY (burst=1, no parallel requests; 4-15 req/sec by call type; weekly
# quotas), so a per-process limiter can't see what the other 3 processes are
# doing. Setting USPTO_SHARED_RATE_LIMIT_DIR points all of them at one
# bind-mounted directory; a cross-process token bucket + a bounded pool of
# concurrency slots, both arbitrated via POSIX file locks (flock — released
# automatically by the kernel on process death, so it's crash-safe), keep
# the combined request rate under the shared key's limits. Leave unset for a
# standalone deployment.
# USPTO_SHARED_RATE_LIMIT_DIR=/var/run/uspto-shared-rate-limit
# USPTO_SHARED_RATE_LIMIT_RPS=4.0       # total tokens/sec across ALL 4 MCPs
# USPTO_SHARED_MAX_CONCURRENT=2         # shared in-flight request slots
